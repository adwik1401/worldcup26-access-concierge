# Copy this file to .env and fill in your own values.
# The app runs fully without an API key (offline multilingual fallback) —
# set these only to upgrade responses to live GenAI composition via OpenRouter.

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any chat-completion model available on OpenRouter. Defaults to a fast,
# inexpensive model suitable for short concierge replies if left unset.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Port the Express server listens on.
PORT=3000
